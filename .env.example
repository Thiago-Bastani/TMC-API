# ─── App ───────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_PORT=80
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate

# ─── Database ──────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ─── Supabase JWT ──────────────────────────────────────────
# Generate keys: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string
SUPABASE_ANON_KEY=CHANGE_ME_jwt_signed_role_anon
SUPABASE_SERVICE_KEY=CHANGE_ME_jwt_signed_role_service_role

# ─── Supabase Realtime ──────────────────────────────────────
REALTIME_SECRET=CHANGE_ME_at_least_64_chars
REALTIME_ENC_KEY=CHANGE_ME_16chars

# ─── Supabase port (Realtime WebSocket for the frontend) ───
SUPABASE_PORT=8000
