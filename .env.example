# ─── App ───────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
APP_PORT=80
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate

# ─── Database ──────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ─── Supabase JWT (sign with JWT_SECRET) ───────────────────
# Generate at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# or use: node -e "const jwt=require('jsonwebtoken'); console.log(jwt.sign({role:'anon',iss:'supabase',iat:1700000000,exp:9999999999},process.env.JWT_SECRET))"
JWT_SECRET=CHANGE_ME_at_least_32_chars_random_string
SUPABASE_ANON_KEY=CHANGE_ME_jwt_signed_with_JWT_SECRET_role_anon
SUPABASE_SERVICE_KEY=CHANGE_ME_jwt_signed_with_JWT_SECRET_role_service_role

# ─── Supabase Realtime ──────────────────────────────────────
REALTIME_SECRET=CHANGE_ME_at_least_64_chars_random_string
REALTIME_ENC_KEY=CHANGE_ME_16_chars_exactly_1234

# ─── Supabase URLs ──────────────────────────────────────────
# Internal: used by Laravel to reach Kong inside Docker network
# Public: exposed to the Electron client
SUPABASE_PUBLIC_URL=http://localhost:8000
SUPABASE_PORT=8000

# ─── Storage ────────────────────────────────────────────────
SUPABASE_STORAGE_BUCKET=messages
